				+button('Транзакции', 'button--black widget__link', '#', 'arrow-link')
				table.widget__table
					tr
						th ID/Клиент
						th Сумма
						th Статус
					tr
						td 10293847
						td ₽4100
						td ОК
					tr
						td 16267384
						td ₽299.5
						td Ожидает
					tr
						td 19290498
						td ₽6670
						td ОК
					tr
						td 04002881
						td ₽2500
						td ОК
					tr
						td 87492342
						td ₽400
						td ОК
					tr
						td 26401232
						td ₽1000
						td Ожидает
					tr
						td 10957366
						td ₽600
