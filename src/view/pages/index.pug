					+icon('server', 'board__icon')
					.board__text +1 сервер хранения...
				.board.board--dark
					.board__line
					+icon('server', 'board__icon')
					.board__text +1 сервер хранения...
				.board.board--dark
					.board__line
					+icon('server', 'board__icon')
					.board__text +1 сервер хранения...
				.board.board--dark
					.board__line
					+icon('server', 'board__icon')
					.board__text +1 сервер хранения...
