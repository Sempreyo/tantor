			.server__widget.server__widget--2.widget
				+button('Аналитика', 'button--black widget__link', '#', 'arrow-link')
				.widget__title query.sql
				.widget__code.
					SELECT <br>
					&nbsp;&nbsp;SUM(amount) AS revenue, <br>
					&nbsp;&nbsp;COUNT(*) AS tx_count, <br>
					&nbsp;&nbsp;AVG(amount) AS avg_check <br>
					FROM transactions <br>
					WHERE status = 'ok' <br>
					&nbsp;&nbsp;AND created_at >= NOW() - "7d" <br>
					GROUP BY day <br>
					ORDER BY day ASC
			.server__widget.server__widget--3.widget.widget--small
				.widget__title Продажи
				.widget__stats
					.widget__stats-item
						p Выручка
						p ₽1.24 млн
						p ↑ 8.3%
					.widget__stats-item
						p Транзакции
						p 4 218
						p ↑ 12%
					.widget__stats-item
						p Средний чек
						p ₽294
						p ↑ 2.1%
				.widget__bars
					.widget__bar
						span Пн
						span.widget__bar-progress(style='--percent: 55%')
						span 55%
					.widget__bar
						span Вт
						span.widget__bar-progress(style='--percent: 72%')
						span 72%
					.widget__bar
						span Ср
						span.widget__bar-progress(style='--percent: 48%')
						span 48%
					.widget__bar
						span Чт
						span.widget__bar-progress(style='--percent: 88%')
						span 88%
					.widget__bar
						span Пт
						span.widget__bar-progress(style='--percent: 95%')
						span 95%
					.widget__bar
						span Сб
						span.widget__bar-progress(style='--percent: 61%')
						span 61%
					.widget__bar
						span Вс
						span.widget__bar-progress(style='--percent: 78%')
						span 78%
				+icon('chart', 'widget__chart-icon')
		#model.server__model
		.advantages.scroll-3
			.container
				.advantages__title.advantages-anim Ваши приложения «выросли» из PostgreSQL? <br> Не спешите их переписывать.
				.advantages__top
					.advantages__text.advantages-anim
						p.
							На&nbsp;PostgreSQL уже работают сотни российских бизнес-приложений, есть зрелая экосистема инструментов и&nbsp;расширений.
						p.
							С&nbsp;ростом нагрузки архитектура усложняется: появляются отдельные СУБД для аналитики, инструменты синхронизации
							данных между контурами, дополнительные слои интеграции. Инфраструктура становится разрозненной и&nbsp;сложной в&nbsp;сопровождении.
					.advantages__net.advantages-anim
						.advantages__net-labels
							span Проблемы с консистентностью
							span Дублирование данных
							span Сложные пайплайны
							span Трудная и дорогая эксплуатация
						.advantages__images
							+picture('machine-3', 'png', 'advantages__image advantages__image--3', '')
							+picture('machine-2', 'png', 'advantages__image advantages__image--2', '')
							+picture('machine-1', 'png', 'advantages__image advantages__image--1', '')
						#graph.advantages__graphs
			.advantages__bottom
				.container.advantages__container-bottom
					.advantages__col
						+picture('server-close', 'png', 'advantages__model-static', '')
						+picture('eleph', 'png', 'advantages__eleph', '')
						.advantages__items
							.advantages__item 100% совместимость <br> с&nbsp;Postgres, 1С и&nbsp;другим ПО
							.advantages__item Обработка транзакций <br> и&nbsp;аналитики
							.advantages__item Горизонтальное <br> масштабирование
					.advantages__col.advantages-anim
						.advantages__text.advantages__text--full.advantages-anim
							p
								b.
									Подход Tantor: 100% совместимость с&nbsp;PostgreSQL и&nbsp;упрощение архитектуры без переписывания кода бизнес-приложений.
							p.
								МБД Tantor XData <sup>Gen3</sup> – горизонтально масштабируемая платформа, которая объединяет OLTP и&nbsp;OLAP в&nbsp;одном
								контуре и сохраняет полную совместимость с&nbsp;PostgreSQL, существующим ПО и&nbsp;расширениями.
							p.
								Инфраструктура остаётся привычной для разработки и эксплуатации, при этом исчезает необходимость в&nbsp;разнородных
								СУБД, синхронизациях и&nbsp;переписывании приложений.
						+button('Как это работает?', 'advantages__link', '#', 'arrow-link')
	section.migration.scroll-4
