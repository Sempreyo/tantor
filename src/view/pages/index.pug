extends ../layouts/default

block vars
	-
		const page = {
			title: 'Tantor'
		};

block main
	section.hero
		.container
			.hero__title Чего бизнес ждет от <br> <span>корпоративной СУБД</span> нового поколения?
		#anchor-1.hero__wrapper.scroll-1
			+icon('plus', 'hero__plus')
			+icon('blob-1', 'blob blob--1')
			.hero__left
				.hero__machines
					.hero__machine.hero__machine--1
						+picture('machine-1', 'png', '', '')
					.hero__machine.hero__machine--2
						+picture('machine-2', 'png', '', '')
					.hero__machine.hero__machine--3
						+picture('machine-3', 'png', '', '')
					.hero__labels
						.hero__label.hero__label--1 Oracle Exadata
						.hero__label.hero__label--2 IBM Netezza
						.hero__label.hero__label--3 SAP HANA
				.hero__car
					+picture('car', 'png', '', '')
			.hero__right
				.hero__text
					span.
						Почему так трудно замещать западные решения в&nbsp;ключевых системах банков, энергетики, промышленности и&nbsp;других
						отраслей с&nbsp;высокими требованиями – тысячи пользователей, потоки транзакций и&nbsp;тяжелая аналитика?
				.hero__text
					span.
						«Классический» PostgreSQL и&nbsp;его производные не&nbsp;позволяют это делать из-за архитектурных ограничений: нет
						горизонтального масштабирования и&nbsp;нельзя эффективно обрабатывать смешанные нагрузки.
				.hero__text
					span.
						Каким может быть выход - читайте в&nbsp;спецпроекте CNews.
	section#anchor-2.server.scroll-2
		+icon('blob-1', 'blob blob--2')
		.server__container.container
			.server__captions
				.server__caption.server__caption--1.caption
					.caption__subtitle Машина баз данных
					.caption__title Tantor XData <sup>Gen3</sup>
				.server__caption.server__caption--2.caption
					.caption__title Новая точка сборки
					.caption__subtitle enterprise-архитектуры
			+picture('server-open', 'png', 'server__model-static', '')
			.server-slider.swiper
				.swiper-wrapper
					.swiper-slide
						.server-slider__subtitle
							span Преодоление ограничений «классического» PostgreSQL
							.server-slider__filler
								span
						.server-slider__title Горизонтальное масштабирование вычислений и&nbsp;хранения
						.server-slider__text
							p.
								МБД Tantor XData Gen3 позволяет масштабировать Compute и Storage в&nbsp;любой момент в&nbsp;зависимости от&nbsp;нагрузки
								в&nbsp;вашей информационной системе.
							p.
								Это именно то, чего недостает «классическому» PostgreSQL.
						+button('Узнать больше', 'server-slider__link', '#', 'arrow-link')
					.swiper-slide
						.server-slider__subtitle
							span Преодоление ограничений «классического» PostgreSQL
							.server-slider__filler
								span
						.server-slider__title Горизонтальное масштабирование вычислений и&nbsp;хранения
						.server-slider__text
							p.
								МБД Tantor XData Gen3 позволяет масштабировать Compute и Storage в&nbsp;любой момент в&nbsp;зависимости от&nbsp;нагрузки
								в&nbsp;вашей информационной системе.
							p.
								Это именно то, чего недостает «классическому» PostgreSQL.
						+button('Подробнее о Tantor XData Gen3', 'server-slider__link', '#', 'arrow-link')
					.swiper-slide
						.server-slider__subtitle
							span Преодоление ограничений «классического» PostgreSQL
							.server-slider__filler
								span
						.server-slider__title Единая платформа для транзакций и&nbsp;аналитики
						.server-slider__text.
							Впервые на российском рынке МБД Tantor XData Gen3 открывает полноценный HTAP — возможность параллельной
							обработки смешанных нагрузок (OLAP+OLTP) на&nbsp;едином наборе данных без&nbsp;дублирования и&nbsp;лишних контуров.
							Важно, что при этом не&nbsp;нарушается совместимость с&nbsp;PostgreSQL.
						+button('Подробнее о Tantor XData Gen3', 'server-slider__link', '#', 'arrow-link')
			.server__config
				+icon('bracket')
				span Начальная конфигурация
			.server__boards
